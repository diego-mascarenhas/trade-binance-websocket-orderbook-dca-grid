#!/usr/bin/env bash
# Short wrapper: dca SYMBOL [long|short|auto]
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

usage() {
    echo "Usage: dca SYMBOL [long|short|auto]"
    echo "  dca 1000PEPEUSDT          # AUTO (default)"
    echo "  dca 1000PEPEUSDT short"
    exit 1
}

[[ $# -lt 1 || $# -gt 2 ]] && usage

SYMBOL="$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')"
DIR="$(printf '%s' "${2:-auto}" | tr '[:upper:]' '[:lower:]')"

case "$DIR" in
    long | short | auto) ;;
    *)
        echo "Direction must be long, short, or auto (got: $2)" >&2
        exit 1
        ;;
esac

exec python3 -u "$ROOT/orderbook_dca_grid.py" "$SYMBOL" \
    --supervise \
    --direction "$DIR" \
    --recv-window 15000
