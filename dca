#!/usr/bin/env bash
# Short wrapper: dca SYMBOL [long|short|auto|stop|status|cleanup]
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT"

usage() {
    echo "Usage: dca SYMBOL [long|short|auto|stop|status|cleanup]"
    echo "  dca 1000PEPEUSDT          # AUTO supervisor (default)"
    echo "  dca 1000PEPEUSDT short    # SHORT supervisor"
    echo "  dca SKLUSDT stop          # stop supervisor (orders stay on Binance)"
    echo "  dca SKLUSDT status        # process + trading state"
    echo "  dca SKLUSDT cleanup       # cancel obstage* Stop/TP algos"
    exit 1
}

[[ $# -lt 1 || $# -gt 2 ]] && usage

SYMBOL="$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')"
ACTION="$(printf '%s' "${2:-auto}" | tr '[:upper:]' '[:lower:]')"

case "$ACTION" in
    stop | status | cleanup)
        exec python3 "$ROOT/botctl.py" "$ACTION" "$SYMBOL"
        ;;
    long | short | auto)
        exec python3 -u "$ROOT/orderbook_dca_grid.py" "$SYMBOL" \
            --supervise \
            --direction "$ACTION" \
            --recv-window 15000
        ;;
    *)
        echo "Second arg must be long, short, auto, stop, status, or cleanup (got: $2)" >&2
        exit 1
        ;;
esac
