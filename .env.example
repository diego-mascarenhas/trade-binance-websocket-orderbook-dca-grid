# Binance Futures USDT-M API keys (copy to .env and fill in)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Optional: override the REST/WS base (mainnet default)
FAPI_BASE=https://fapi.binance.com

# Optional: default entry size (CLI flags override these)
# WALLET_PCT = entry as % of wallet balance (used when BASE_SIZE=0)
WALLET_PCT=10
# BASE_SIZE = fixed base order size in USDT (0 = use WALLET_PCT)
BASE_SIZE=0

# Optional: skip opening if the book is too one-sided.
# MAX_IMBALANCE = max allowed % difference between bid and ask volume near mid
# (measured within the --auto-range band). 0 = off. Override at runtime with --force.
# e.g. bid 790 vs ask 116 => ~74% difference => skipped when MAX_IMBALANCE=30
MAX_IMBALANCE=30
