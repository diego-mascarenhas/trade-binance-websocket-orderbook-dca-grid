# Binance Futures USDT-M API keys (copy to .env and fill in)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Optional: override the REST/WS base (mainnet default)
FAPI_BASE=https://fapi.binance.com

# Optional: default entry size (CLI flags override these)
# WALLET_PCT = entry as % of wallet balance (used when BASE_SIZE=0)
WALLET_PCT=10
# BASE_SIZE = fixed base order size in USDT (0 = use WALLET_PCT)
BASE_SIZE=0

# Optional: keep your account's LONG/SHORT exposure balanced.
# MAX_IMBALANCE = max allowed % difference between total LONG and SHORT notional
# across ALL open positions: |LONG - SHORT| / (LONG + SHORT) * 100.
# Before opening, if adding to the heavier side would exceed this, that side is
# skipped (the lighter side is still allowed since it rebalances). 0 = off.
# Override at runtime with --force.
# e.g. LONG 748 vs SHORT 349 => ~36% difference => new LONG skipped when MAX_IMBALANCE=20
MAX_IMBALANCE=20

# Account risk guards (futures) — 0 disables each check. --force overrides blocks.
# MAX_MARGIN_PCT=50           # skip if projected initial margin / balance > 50%
# MIN_LIQ_DISTANCE_PCT=20     # skip if any position is closer than 20% to liquidation
# MAX_ACCOUNT_NOTIONAL_PCT=80 # skip if total |notional| + grid > wallet×lev×80%
# RISK_USE_FULL_GRID=true       # use full DCA grid notional in checks (not entry only)

# Optional (--supervise): when flat but a grid can't be armed (imbalance guard,
# no walls...), wait this many seconds before retrying instead of --tp-poll-sec.
# Avoids hammering the API / spamming logs. Default 60.
REARM_BACKOFF=60

# Base/entry LIMIT order auto-expires via GTD (seconds). DCA safety orders stay GTC.
# If entry expires unfilled, --supervise cancels the orphan DCA grid and re-arms.
# 0 = no GTD (all orders use GTC). Default 1h. Min 600 for GTD.
# Tip: with GRID_TTL below, set ORDER_TTL=0 so refresh is proactive (not only on entry expiry).
ORDER_TTL=3600
# Flat armed grid refresh (Futures + Spot): cancel + re-arm at current book walls after N seconds.
# --supervise only, while flat. 0 = off. Default 1h.
GRID_TTL=3600

# --- Futures bot defaults (orderbook_dca_grid.py) -------------------------
# Exit mode for --supervise: trailing | staged | none (default: staged)
# EXIT_MODE=staged
# Binance recvWindow (default 15000; lower if your clock is very tight)
# RECV_WINDOW=15000
# DIRECTION=auto

# --- Staged exit (--exit staged / EXIT_MODE=staged) -----------------------
# TP1_PROFIT_PCT=0.3
# TP_PARTIAL_PCT=70
# BE_PROFIT_PCT=0.1
# SL_PCT=2
# STAGED_POLL_SEC=5

# systemd pair lists — used by deploy/sync_pairs.py (enable/start listed, disable the rest)
# Comment out a line entirely to leave that market untouched by sync.
# FUTURES_UNIT=dca-futures   # override if needed (default in sync_pairs.py)
FUTURES_PAIRS=1000SHIBUSDT,ATOMUSDT,AVAXUSDT,DOGEUSDT,EIGENUSDT,ETCUSDT,NEARUSDT,OPUSDT,SUIUSDT,XRPUSDT

# --- Telegram (alerts + remote control) -----------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# BOTCTL_MODE=auto      # auto | systemd | pidfile
# TELEGRAM_MIN_OPEN_VOL=5
# DEEPSEEK_API_KEY=          # pick — one volatile trade (skips FUTURES_PAIRS fleet)
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE=https://api.deepseek.com
# Run daemon: python3 telegram_botctl.py
# CLI:        python3 botctl.py start|stop|status SXTUSDT
# Scan:       fscan / python3 futures_scan.py
# AI pick:    pick / python3 trade_pick.py  (needs DEEPSEEK_API_KEY)
# AI review:  review NEARUSDT  — situational analysis for open position (needs DEEPSEEK_API_KEY)

# --- OB scalp (orderbook_ob_scalp.py) — separate from DCA grid ----------------
# SCALP_WALLET_PCT=2       # with --size-mode wallet
# SCALP_BASE_SIZE=0        # with --size-mode fixed (USDT notional)
# SCALP_SIZE_MODE=min      # min (default) | wallet | fixed
# OB_BAR_SEC=60            # internal bar length (seconds)
# OB_SAMPLE_SEC=2          # depth poll interval while building a bar
# OB_BAND_PCT=1            # book band around mid for imbalance
# OB_IMB_LONG=0.55         # enter long when bid share >= this
# OB_IMB_SHORT=0.45        # enter short when bid share <= this
# OB_TP_PCT=0.35           # take profit %
# OB_SL_PCT=0.25           # stop loss %
# OB_FEE_BUFFER=0.08       # skip TP/flip close if gross - buffer <= 0
# OB_RECOVER=1              # double size after losing close until TP (same side only)
# OB_RECOVER_MAX_LEVEL=4    # cap at 16x base notional
# OB_ENTRY_COOLDOWN_SEC=45  # wait after close before re-entry
# Logs: .run/logs/SYMBOL/scalp_trades.log + scalp_recovery.json
# Run: obscalp BTCUSDT --dry-run  |  obscalp HEIUSDT --execute --bar-sec 15

SPOT_PAIRS=BNBUSDT,BTCUSDT,ETHUSDT,SOLUSDT

# --- SPOT bot only (orderbook_dca_grid_spot.py) --------------------------
# Same API keys as futures (needs "Spot & Margin Trading" permission).
# Optional: override the Spot REST base (mainnet default)
SPOT_BASE=https://api.binance.com
# OCO exit anchored to the order book:
# SPOT_TP = min take-profit % above avg (TP sits on an ask wall at/above it).
SPOT_TP=0.5
# The stop-loss is placed BELOW the whole DCA grid (under the deepest open DCA),
# so the grid can play out before cutting. SPOT_SL is only the fallback distance
# below avg when the grid is fully filled; SPOT_SL_BUFFER is the extra cushion
# below the grid bottom for the stop trigger.
SPOT_SL=5
SPOT_SL_BUFFER=0.5
# Floor for the wallet-% entry size: if WALLET_PCT of free USDT is below this,
# use this many USDT instead (keeps orders above minNotional). Default 10.
MIN_BASE_USDT=10
# DCA count comes from the real walls in the book (a level is a wall if its size
# is ≥ SO_WALL_MULT × median book size). SO_MAX is only a safety cap (0 = no cap).
SO_MAX=15
SO_WALL_MULT=2
# Max invested per symbol. Prefer a % of the wallet (total USDT); the absolute
# Per-symbol exposure cap (Spot): holding + full grid cost must fit.
# MAX_SYMBOL_PCT = % of total USDT wallet (default 25%). Deepest DCAs are trimmed if needed.
# MAX_SYMBOL_USDT is a fallback used only when MAX_SYMBOL_PCT=0. 0 on both = no cap.
MAX_SYMBOL_PCT=25
MAX_SYMBOL_USDT=0
