# Binance Futures USDT-M API keys (copy to .env and fill in)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Optional: override the REST/WS base (mainnet default)
FAPI_BASE=https://fapi.binance.com

# Optional: default entry size (CLI flags override these)
# WALLET_PCT = entry as % of wallet balance (used when BASE_SIZE=0)
WALLET_PCT=10
# BASE_SIZE = fixed base order size in USDT (0 = use WALLET_PCT)
BASE_SIZE=0

# Optional: keep your account's LONG/SHORT exposure balanced.
# MAX_IMBALANCE = max allowed % difference between total LONG and SHORT notional
# across ALL open positions: |LONG - SHORT| / (LONG + SHORT) * 100.
# Before opening, if adding to the heavier side would exceed this, that side is
# skipped (the lighter side is still allowed since it rebalances). 0 = off.
# Override at runtime with --force.
# e.g. LONG 748 vs SHORT 349 => ~36% difference => new LONG skipped when MAX_IMBALANCE=30
MAX_IMBALANCE=30

# Optional (--supervise): when flat but a grid can't be armed (imbalance guard,
# no walls...), wait this many seconds before retrying instead of --tp-poll-sec.
# Avoids hammering the API / spamming logs. Default 60.
REARM_BACKOFF=60

# Base/entry LIMIT order auto-expires via GTD (seconds). DCA safety orders stay GTC.
# If entry expires unfilled, --supervise cancels the orphan DCA grid and re-arms.
# 0 = no GTD (all orders use GTC). Default 1h. Min 600 for GTD.
ORDER_TTL=3600

# systemd pair lists — used by deploy/sync_pairs.py (enable/start listed, disable the rest)
# Comment out a line entirely to leave that market untouched by sync.
# FUTURES_UNIT=dca-futures   # override if needed (default in sync_pairs.py)
FUTURES_PAIRS=1000SHIBUSDT,ATOMUSDT,AVAXUSDT,DOGEUSDT,EIGENUSDT,ETCUSDT,NEARUSDT,OPUSDT,SUIUSDT,XRPUSDT
SPOT_PAIRS=BNBUSDT,BTCUSDT,ETHUSDT,SOLUSDT

# --- SPOT bot only (orderbook_dca_grid_spot.py) --------------------------
# Same API keys as futures (needs "Spot & Margin Trading" permission).
# Optional: override the Spot REST base (mainnet default)
SPOT_BASE=https://api.binance.com
# OCO exit anchored to the order book:
# SPOT_TP = min take-profit % above avg (TP sits on an ask wall at/above it).
SPOT_TP=0.5
# The stop-loss is placed BELOW the whole DCA grid (under the deepest open DCA),
# so the grid can play out before cutting. SPOT_SL is only the fallback distance
# below avg when the grid is fully filled; SPOT_SL_BUFFER is the extra cushion
# below the grid bottom for the stop trigger.
SPOT_SL=5
SPOT_SL_BUFFER=0.5
# Floor for the wallet-% entry size: if WALLET_PCT of free USDT is below this,
# use this many USDT instead (keeps orders above minNotional). Default 10.
MIN_BASE_USDT=10
# DCA count comes from the real walls in the book (a level is a wall if its size
# is ≥ SO_WALL_MULT × median book size). SO_MAX is only a safety cap (0 = no cap).
SO_MAX=15
SO_WALL_MULT=2
# Max invested per symbol. Prefer a % of the wallet (total USDT); the absolute
# Per-symbol exposure cap (Spot): holding + full grid cost must fit.
# MAX_SYMBOL_PCT = % of total USDT wallet (default 25%). Deepest DCAs are trimmed if needed.
# MAX_SYMBOL_USDT is a fallback used only when MAX_SYMBOL_PCT=0. 0 on both = no cap.
MAX_SYMBOL_PCT=25
MAX_SYMBOL_USDT=0
# Flat armed grid refresh (Spot only): cancel + re-arm at current book walls after N seconds.
# Spot has no native GTD on LIMIT orders. 0 = off. Default 1h.
GRID_TTL=3600
